{
	"manifest_version": 3,
	"name": "MundaManager FR",
	"version": "1.0",
	"description": "Traduction française de mundamanager.com (Necromunda)",
	"icons": {
		"16": "icon.png",
		"48": "icon.png",
		"128": "icon.png"
	},
	"content_scripts": [
		{
			"matches": ["*://www.mundamanager.com/*"],
			"js": ["translations.js", "content.js"],
			"run_at": "document_idle"
		}
	]
}
